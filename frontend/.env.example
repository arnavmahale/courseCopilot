# Vite — copy to .env.local (never commit secrets)
#
# Do NOT put OPENAI_API_KEY here. The browser cannot keep secrets; transcript
# evaluation calls the Python API, which reads OPENAI_API_KEY from the repo
# root .env (see courseCopilot/.env.example) or from your API host env
# (e.g. Railway Variables on the backend service).

# Supabase (optional until you wire auth; evaluation storage uses this when set)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When API is on another origin (e.g. separate Railway service). Set on the host that RUNS
# `npm run build` (Railway Variables for the frontend service) — Vite bakes this in at build time.
# No trailing slash. If the API app is mounted at /api on the same host as the SPA, use default /api (omit this).
# Pure API service (uvicorn, no /api prefix): VITE_API_URL=https://your-api.up.railway.app
# Single Docker image (same host): leave unset so the client uses relative /api.
